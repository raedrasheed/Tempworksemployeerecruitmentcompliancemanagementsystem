# Frontend Environment Variables
# Use relative path for production (proxied via .htaccess); use http://localhost:3000/api/v1 for local dev
VITE_API_URL=/api/v1
VITE_APP_NAME=TempWorks Europe

# Google reCAPTCHA v2 site key (get from https://www.google.com/recaptcha/admin)
VITE_RECAPTCHA_SITE_KEY=your_site_key_here
