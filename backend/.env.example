# Database
# Supported libpq sslmode values (see backend/prisma/pg-ssl.ts):
#   disable      — no SSL (typical for local dev Postgres)
#   allow        — no SSL (libpq's "try plain, then SSL" fallback is not
#                  supported by node-pg; treated as disable)
#   prefer       — SSL without certificate verification
#   require      — SSL without certificate verification (common for managed
#                  cloud databases that issue self-signed certs)
#   verify-ca    — SSL with CA chain verification, hostname check skipped
#   verify-full  — SSL with full CA + hostname verification (strictest)
#
# When `sslmode` is omitted, SSL is disabled. Set it explicitly on managed
# or production databases that require TLS. The mode is also forwarded to
# pg_dump / pg_restore via PGSSLMODE so backups work against SSL-only hosts.
DATABASE_URL="postgresql://postgres:password@localhost:5432/tempworks_db?sslmode=disable"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# File Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760

# Admin Seed
SEED_ADMIN_EMAIL=admin@tempworks.com
SEED_ADMIN_PASSWORD=Admin@123456
