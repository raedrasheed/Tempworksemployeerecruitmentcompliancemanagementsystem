{
  "name": "tempworks-backend",
  "version": "1.0.0",
  "description": "TempWorks Europe Recruitment Compliance Management System - Backend API",
  "scripts": {
    "build": "prisma generate && node -e \"try{require('fs').unlinkSync('dist/tsconfig.build.tsbuildinfo')}catch(e){}\" && nest build",
    "build:server": "node -e \"try{require('fs').unlinkSync('dist/tsconfig.build.tsbuildinfo')}catch(e){}\" && nest build",
    "start": "nest start",
    "start:dev": "prisma generate && node -e \"try{require('fs').unlinkSync('dist/tsconfig.build.tsbuildinfo')}catch(e){}\" && nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "db:migrate:finance": "ts-node prisma/run-financial-migration.ts",
    "db:migrate:job-ads": "ts-node prisma/run-job-ads-migration.ts",
    "db:migrate:doc-enhancements": "ts-node prisma/run-document-enhancements.ts",
    "db:migrate:recycle-bin": "ts-node prisma/run-recycle-bin-migration.ts",
    "db:migrate:financial-continuity": "ts-node prisma/run-financial-continuity-migration.ts",
    "db:migrate:pipeline": "ts-node prisma/run-pipeline-migration.ts",
    "db:migrate:rename-workflow": "ts-node prisma/run-rename-migration.ts",
    "db:migrate:isactive": "ts-node prisma/run-isactive-migration.ts",
    "db:migrate:employee-workflow": "ts-node prisma/run-employee-workflow-migration.ts",
    "db:migrate:employee-workflow-stage": "ts-node prisma/run-employee-workflow-current-stage-migration.ts",
    "db:migrate:employee-stage-approvals": "ts-node prisma/run-employee-stage-approvals-migration.ts",
    "db:migrate:attendance": "ts-node prisma/run-attendance-migration.ts",
    "db:migrate:vehicles": "ts-node prisma/run-vehicles-migration.ts",
    "db:migrate:employee-job-type": "ts-node prisma/run-employee-job-type-migration.ts",
    "db:migrate:vehicle-soft-deletes": "ts-node prisma/run-vehicle-soft-deletes-migration.ts",
    "db:migrate:backup": "ts-node prisma/run-backup-migration.ts",
    "db:migrate:user-profile": "ts-node prisma/run-user-profile-migration.ts",
    "db:migrate:backfill-nationality": "ts-node prisma/run-backfill-nationality.ts",
    "db:migrate:drop-applicant-email-unique": "ts-node prisma/run-drop-applicant-email-unique.ts",
    "db:migrate:job-ads-required-docs": "ts-node prisma/run-job-ads-required-documents-migration.ts",
    "db:migrate:two-factor": "ts-node prisma/run-two-factor-migration.ts",
    "db:migrate:agency-profile": "ts-node prisma/run-agency-profile-fields-migration.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^5.1.2",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@types/nodemailer": "^8.0.0",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.10.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.8",
    "prisma": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.3"
  }
}
