generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
  TERMINATED
}

enum AgencyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  PENDING
  ONBOARDING
  TERMINATED
  ON_LEAVE
}

enum ApplicantStatus {
  NEW
  SCREENING
  INTERVIEW
  OFFER
  ACCEPTED
  REJECTED
  WITHDRAWN
  ONBOARDING
}


enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
  EXPIRING_SOON
}

enum WorkflowStageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  BLOCKED
}

enum WorkPermitStatus {
  PENDING
  APPLIED
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum VisaStatus {
  PENDING
  APPLIED
  APPOINTMENT_SCHEDULED
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ApplicantTier {
  LEAD
  CANDIDATE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  COMPLIANCE
  DOCUMENT_EXPIRY
  WORKFLOW
  SYSTEM
  FINANCIAL
}

enum EntityType {
  EMPLOYEE
  APPLICANT
  APPLICATION
  AGENCY
  USER
}

enum WorkflowCategory {
  INITIAL
  DOCUMENTATION
  COMPLIANCE
  TRAINING
  DEPLOYMENT
  ADMINISTRATIVE
}

model Role {
  id              String    @id @default(uuid())
  name            String    @unique
  description     String?
  isSystem        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  deletedBy       String?
  deletionReason  String?

  permissions          RolePermission[]
  users                User[]
  docTypePermissions   DocumentTypePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid())
  name      String   @unique
  module    String
  action    String
  createdAt DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id            String      @id @default(uuid())
  userNumber    String?     @unique
  email         String      @unique
  passwordHash  String
  firstName     String
  middleName    String?
  lastName      String
  phone         String?
  dateOfBirth   DateTime?
  gender        Gender?
  citizenship   String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  country       String?
  postalCode    String?
  jobTitle      String?
  department    String?
  startDate     DateTime?
  photoUrl      String?
  roleId        String
  status        UserStatus  @default(ACTIVE)
  agencyId      String
  lastLoginAt   DateTime?
  refreshToken  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  deletedBy     String?
  deletionReason String?

  // Auth security fields
  failedLoginAttempts Int      @default(0)
  lockedAt            DateTime?
  passwordChangedAt   DateTime?
  passwordExpiresAt   DateTime?

  // Preferences
  preferredLanguage String?  @default("en")
  timeZone          String?  @default("UTC")
  notificationPrefs Json?

  // Self-referencing creator relation
  createdById   String?
  createdBy     User?    @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers  User[]   @relation("UserCreatedBy")

  role   Role   @relation(fields: [roleId], references: [id])
  agency Agency @relation(fields: [agencyId], references: [id])

  notifications     Notification[]
  auditLogs         AuditLog[]
  uploadedDocuments Document[]     @relation("UploadedDocuments")
  verifiedDocuments Document[]     @relation("VerifiedDocuments")
  assignedStages    EmployeeStage[] @relation("AssignedStages")

  // ── Financial record relations ─────────────────────────────────────────
  financialRecordsPaidBy     FinancialRecord[]            @relation("FRPaidBy")
  financialRecordsCreated    FinancialRecord[]            @relation("FRCreatedBy")
  financialAttachments       FinancialRecordAttachment[]  @relation("FRAttachmentUploadedBy")

  resolvedAlerts    ComplianceAlert[] @relation("ResolvedAlerts")
  updatedSettings   SystemSetting[]
  jobAdsCreated     JobAd[]           @relation("JobAdsCreated")

  // ── Workflow relations ─────────────────────────────────────────────────
  workflowsCreated      Workflow[]                    @relation("WorkflowsCreated")
  workflowStageUsers    WorkflowStageUser[]            @relation("WorkflowStageUsers")
  workflowAccess        WorkflowAccessUser[]           @relation("WorkflowAccess")
  workflowAssignments         CandidateWorkflowAssignment[]  @relation("WorkflowAssignments")
  employeeWorkflowAssignments EmployeeWorkflowAssignment[]   @relation("EmployeeWorkflowAssignments")
  stageApprovals           CandidateStageApproval[]      @relation("StageApprovals")
  employeeStageApprovals   EmployeeStageApproval[]       @relation("EmployeeStageApprovals")
  attendanceCreated        AttendanceRecord[]            @relation("AttendanceCreatedBy")
  attendanceUpdated        AttendanceRecord[]            @relation("AttendanceUpdatedBy")
  stageNotes            CandidateStageNote[]           @relation("StageNoteAuthors")

  // ── Vehicle relations ──────────────────────────────────────────────────
  vehiclesCreated         Vehicle[]                     @relation("VehicleCreatedBy")
  vehiclesUpdated         Vehicle[]                     @relation("VehicleUpdatedBy")
  vehicleDocsUploaded     VehicleDocument[]             @relation("VehicleDocUploadedBy")
  maintenanceCreated      MaintenanceRecord[]           @relation("MaintenanceCreatedBy")
  maintenanceUpdated      MaintenanceRecord[]           @relation("MaintenanceUpdatedBy")
  systemBackups           SystemBackup[]                @relation("BackupCreatedBy")

  // Agency manager back-relation
  managedAgencies   Agency[] @relation("AgencyManager")

  // Token relations
  activationTokens        ActivationToken[]
  passwordResetTokens     PasswordResetToken[]
  deleteRequests          CandidateDeleteRequest[] @relation("DeleteRequestedBy")
  reviewedDeleteRequests  CandidateDeleteRequest[] @relation("DeleteRequestReviewedBy")
  permissionOverrides     AgencyUserPermission[]

  @@map("users")
}

model Agency {
  id                 String       @id @default(uuid())
  name               String
  country            String
  contactPerson      String
  email              String
  phone              String
  status             AgencyStatus @default(ACTIVE)
  logoUrl            String?
  notes              String?
  maxUsersPerAgency  Int          @default(10)
  managerId          String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?
  deletedBy          String?
  deletionReason     String?

  users      User[]
  employees  Employee[]
  applicants Applicant[]
  vehicles   Vehicle[]
  manager    User?    @relation("AgencyManager", fields: [managerId], references: [id])

  @@map("agencies")
}

model Employee {
  id                    String         @id @default(uuid())
  employeeNumber        String?        @unique
  // ── Lifecycle traceability ────────────────────────────────────────────────
  // Copied from applicant at conversion time so prior-stage IDs survive
  // even after the applicant record is soft-deleted.
  leadNumber            String?
  candidateNumber       String?
  candidateConvertedAt  DateTime?
  employeeConvertedAt   DateTime?
  // ── Core identity ─────────────────────────────────────────────────────────
  firstName        String
  lastName         String
  email            String         @unique
  phone            String
  nationality      String
  status           EmployeeStatus @default(PENDING)
  dateOfBirth      DateTime
  licenseNumber    String?
  licenseCategory  String?
  yearsExperience  Int            @default(0)
  jobTypeId        String?
  agencyId         String?
  photoUrl         String?
  addressLine1     String
  addressLine2     String?
  city             String
  country          String
  postalCode       String
  emergencyContact String?
  emergencyPhone   String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  deletedBy        String?
  deletionReason   String?

  agency   Agency?   @relation(fields: [agencyId], references: [id])
  jobType  JobType?  @relation(fields: [jobTypeId], references: [id])
  employeeStages EmployeeStage[]
  workPermits    WorkPermit[]
  workflowAssignments    EmployeeWorkflowAssignment[]
  stageApprovals         EmployeeStageApproval[]
  attendanceRecords      AttendanceRecord[]      @relation("EmployeeAttendance")
  vehicleAssignments     VehicleDriverAssignment[]

  @@map("employees")
}

model StageTemplate {
  id                   String           @id @default(uuid())
  name                 String           @unique
  order                Int
  description          String?
  color                String           @default("#2563EB")
  category             WorkflowCategory @default(INITIAL)
  isActive             Boolean          @default(true)
  requirementsDocuments String[]        @default([])
  requirementsActions  String[]         @default([])
  requirementsApprovals String[]        @default([])
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  employeeStages    EmployeeStage[]
  applicantsCurrent Applicant[]     @relation("ApplicantCurrentStage")

  @@map("stage_templates")
}

model EmployeeStage {
  id           String              @id @default(uuid())
  employeeId   String
  stageId      String
  status       WorkflowStageStatus @default(PENDING)
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String?
  assignedToId String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  stage      StageTemplate @relation(fields: [stageId], references: [id])
  assignedTo User?         @relation("AssignedStages", fields: [assignedToId], references: [id])

  @@unique([employeeId, stageId])
  @@map("employee_stages")
}

model JobType {
  id                String   @id @default(uuid())
  name              String   @unique
  description       String?
  requiredDocuments String[] @default([])
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  applicants Applicant[]
  employees  Employee[]

  @@map("job_types")
}

model Applicant {
  id                      String          @id @default(uuid())
  tier                    ApplicantTier   @default(LEAD)
  // ── Core identity ─────────────────────────────────────────────────────────
  firstName               String
  middleName              String?
  lastName                String
  email                   String          @unique
  phone                   String
  // citizenship replaces nationality (nationality kept for backward compat)
  nationality             String?
  citizenship             String?
  gender                  Gender?
  dateOfBirth             DateTime?
  countryOfBirth          String?
  cityOfBirth             String?
  photoUrl                String?
  hasDrivingLicense       Boolean         @default(false)
  // ── Status & assignment ───────────────────────────────────────────────────
  status                  ApplicantStatus @default(NEW)
  jobTypeId               String?
  agencyId                String?
  // ── Legacy flat fields (kept for backward compat) ─────────────────────────
  residencyStatus         String?
  hasNationalInsurance    Boolean         @default(false)
  nationalInsuranceNumber String?
  hasWorkAuthorization    Boolean         @default(false)
  workAuthorizationType   String?
  workAuthorizationExpiry DateTime?
  preferredStartDate      DateTime?
  availability            String?
  willingToRelocate       Boolean         @default(false)
  preferredLocations      String?
  salaryExpectation       String?
  notes                   String?
  // ── Lifecycle identifiers ─────────────────────────────────────────────────
  // leadNumber:       assigned at creation          (A + YYYY + MM + 5-digit serial)
  // candidateNumber:  assigned at Lead→Candidate    (C + YYYY + MM + 5-digit serial)
  // employeeConvertedAt: timestamp of Candidate→Employee conversion
  // Serial resets monthly per prefix; generated via identifier_sequences table
  leadNumber              String?
  candidateNumber         String?
  candidateConvertedAt    DateTime?
  employeeConvertedAt     DateTime?
  // ── Rich structured application data (JSON) ───────────────────────────────
  // Stores: addresses, passport, ID, visa, residence, work permit, criminal records,
  // driving license details, driving experience, education[], workHistory[],
  // skills, emergency contact, additional info, declaration
  applicationData         Json?
  convertedToEmployeeId   String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  deletedAt               DateTime?
  deletedBy               String?
  deletionReason          String?

  currentWorkflowStageId String?

  // ── Job Ad linkage ────────────────────────────────────────────────────────
  jobAdId                 String?
  jobAd                   JobAd?          @relation(fields: [jobAdId], references: [id])

  jobType              JobType?       @relation(fields: [jobTypeId], references: [id])
  agency               Agency?        @relation(fields: [agencyId], references: [id])
  currentWorkflowStage StageTemplate? @relation("ApplicantCurrentStage", fields: [currentWorkflowStageId], references: [id])
  financialProfile     ApplicantFinancialProfile?
  agencyHistory        ApplicantAgencyHistory[]
  workflowAssignments  CandidateWorkflowAssignment[]
  deleteRequests       CandidateDeleteRequest[]

  @@map("applicants")
}

model ApplicantFinancialProfile {
  id              String    @id @default(uuid())
  applicantId     String    @unique
  employeeId      String?   @unique  // set when applicant is converted to employee; enables lookup from employee profile
  bankName        String?
  accountHolder   String?
  accountNumber   String?
  sortCode        String?
  iban            String?
  bankAddress     String?
  taxCode         String?
  niNumber        String?
  paymentMethod   String?
  salaryAgreed    Decimal?  @db.Decimal(10, 2)
  currency        String    @default("GBP")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("applicant_financial_profiles")
}

model ApplicantAgencyHistory {
  id           String    @id @default(uuid())
  applicantId  String
  agencyId     String?
  agencyName   String
  assignedAt   DateTime  @default(now())
  removedAt    DateTime?
  assignedById String?
  reason       String?
  notes        String?

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("applicant_agency_history")
}


model DocumentType {
  id                String    @id @default(uuid())
  name              String    @unique
  /// Short uppercase code used in business document IDs, e.g. PASS, VISA, TRC.
  /// Generated from the first 4 chars of name if not set explicitly.
  code              String?
  description       String?
  category          String
  required          Boolean   @default(false)
  trackExpiry       Boolean   @default(true)
  renewalPeriodDays Int?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  deletedBy         String?
  deletionReason    String?

  documents         Document[]
  permissions       DocumentTypePermission[]
  workflowStageReqs WorkflowStageRequiredDoc[]

  @@map("document_types")
}

model Document {
  id              String         @id @default(uuid())
  /// Business document ID: DOC{PersonNumber}{TypeCode}{3-digit sequence}
  /// E.g. DOCC20260400001PASS001 — unique per non-null value.
  docId           String?        @unique
  name            String
  documentTypeId  String
  entityType      EntityType
  entityId        String
  fileUrl         String
  mimeType        String
  fileSize        Int
  status          DocumentStatus @default(PENDING)
  issueDate       DateTime?
  expiryDate      DateTime?
  issueCountry    String?
  issuer          String?
  documentNumber  String?
  notes           String?
  /// Populated when status = REJECTED; stored separately from notes.
  rejectionReason String?
  uploadedById    String
  verifiedById    String?
  verifiedAt      DateTime?
  /// Self-reference: points to the document this one renews/supersedes.
  renewedFromId   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  deletedBy       String?
  deletionReason  String?

  documentType     DocumentType     @relation(fields: [documentTypeId], references: [id])
  uploadedBy       User             @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  verifiedBy       User?            @relation("VerifiedDocuments", fields: [verifiedById], references: [id])
  complianceAlerts ComplianceAlert[]
  renewedFrom      Document?        @relation("DocumentRenewal", fields: [renewedFromId], references: [id])
  renewals         Document[]       @relation("DocumentRenewal")

  @@index([entityType, entityId])
  @@index([status])
  @@index([documentTypeId])
  @@index([expiryDate])
  @@map("documents")
}

/// Fine-grained per-document-type permissions per role.
/// A missing row means the role uses its general documents:* permission.
model DocumentTypePermission {
  id             String   @id @default(uuid())
  documentTypeId String
  roleId         String
  canUpload      Boolean  @default(true)
  canView        Boolean  @default(true)
  canEdit        Boolean  @default(false)
  canDelete      Boolean  @default(false)
  canRenew       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  documentType DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([documentTypeId, roleId])
  @@map("document_type_permissions")
}

model WorkPermit {
  id               String           @id @default(uuid())
  employeeId       String
  permitType       String
  status           WorkPermitStatus @default(PENDING)
  permitNumber     String?
  applicationDate  DateTime
  approvalDate     DateTime?
  expiryDate       DateTime
  issuingAuthority String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("work_permits")
}

model Visa {
  id              String     @id @default(uuid())
  entityType      EntityType
  entityId        String
  visaType        String
  status          VisaStatus @default(PENDING)
  visaNumber      String?
  applicationDate DateTime
  appointmentDate DateTime?
  approvalDate    DateTime?
  expiryDate      DateTime?
  embassy         String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt


  @@map("visas")
}

model Notification {
  id              String           @id @default(uuid())
  userId          String
  title           String
  message         String
  type            NotificationType @default(INFO)
  // Specific event type string (e.g. DOCUMENT_UPLOADED, FINANCIAL_RECORD_CREATED)
  eventType       String?
  // Delivery channel: in_app | email
  channel         String           @default("in_app")
  isRead          Boolean          @default(false)
  readAt          DateTime?
  relatedEntity   String?
  relatedEntityId String?
  createdAt       DateTime         @default(now())
  deletedAt       DateTime?
  deletedBy       String?
  deletionReason  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, eventType])
  @@index([userId, type])
  @@map("notifications")
}

model AuditLog {
  id             String    @id @default(uuid())
  userId         String?
  userEmail      String?
  action         String
  entity         String
  entityId       String
  changes        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model ComplianceAlert {
  id             String        @id @default(uuid())
  entityType     EntityType
  entityId       String
  documentId     String?
  alertType      String
  severity       AlertSeverity @default(MEDIUM)
  message        String
  status         AlertStatus   @default(OPEN)
  dueDate        DateTime?
  resolvedAt     DateTime?
  resolvedById   String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  document   Document?  @relation(fields: [documentId], references: [id])
  resolvedBy User?      @relation("ResolvedAlerts", fields: [resolvedById], references: [id])

  @@map("compliance_alerts")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  category    String
  isPublic    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  updatedById String?

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("system_settings")
}

model NotificationRule {
  id              String    @id @default(uuid())
  name            String
  trigger         String
  entityType      String
  daysBeforeExpiry Int?
  channels        String[]
  recipientRoles  String[]
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  deletedBy       String?
  deletionReason  String?

  @@map("notification_rules")
}

// ─── Dynamic Reporting ───────────────────────────────────────────────────────

model Report {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  dataSource  String    // employees | applicants | documents | compliance_alerts | agencies | work_permits
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedBy   String?
  deletionReason String?

  filters  ReportFilter[]
  columns  ReportColumn[]
  sorting  ReportSorting[]

  @@map("reports")
}

model ReportFilter {
  id        String  @id @default(uuid())
  reportId  String
  fieldName String
  operator  String  // eq | ne | gt | gte | lt | lte | like | between | in | is_null | is_not_null
  value     String  @default("")
  value2    String? // used for BETWEEN
  valueType String  @default("string") // string | number | date | boolean

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_filters")
}

model ReportColumn {
  id              String  @id @default(uuid())
  reportId        String
  columnName      String
  displayName     String
  dataType        String  @default("string") // string | number | date | boolean | enum
  isGrouped       Boolean @default(false)
  isAggregated    Boolean @default(false)
  aggregationType String? // COUNT | SUM | AVG | MIN | MAX
  position        Int     @default(0)

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_columns")
}

model ReportSorting {
  id         String @id @default(uuid())
  reportId   String
  columnName String
  direction  String @default("ASC")
  position   Int    @default(0)

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_sorting")
}

// ── Lifecycle Identifier Sequences ───────────────────────────────────────────
// One row per (prefix, year, month).  The "current" counter is atomically
// incremented via INSERT … ON CONFLICT DO UPDATE so concurrent requests
// never produce duplicate identifiers.
//
// Prefix meanings:
//   A  →  Lead / Application  (assigned at applicant creation)
//   C  →  Candidate           (assigned at Lead→Candidate conversion)
//   E  →  Employee            (assigned at Candidate→Employee conversion)
//
// Serial format:  [prefix][YYYY][MM][SSSSS]
// Example IDs:    A20260400001  C20260400001  E20260400001
// Serials reset to 1 at the start of each new month per prefix.
model IdentifierSequence {
  id      String @id @default(uuid())
  prefix  String  // 'A' | 'C' | 'E'
  year    Int
  month   Int
  current Int     @default(0)

  @@unique([prefix, year, month])
  @@map("identifier_sequences")
}

// ── Financial Records ─────────────────────────────────────────────────────────
//
// Tracks all money disbursements made by the company to/for a Candidate or
// Employee for payroll-deduction reconciliation purposes.
//
// ACCOUNTING RULES (explicit):
//  - companyDisbursedAmount   : money paid BY the company FOR/TO the person.
//                               Included in all balance calculations.
//  - employeeOrAgencyPaidAmount: money paid BY the person or their agency.
//                               Informational only — NOT included in balance.
//  - Current Balance          : SUM(companyDisbursedAmount)
//                               - SUM(deductionAmount WHERE NOT NULL)
//  - Partial deduction IS supported: deductionAmount ≤ companyDisbursedAmount.
//  - Status PENDING  : not yet fully deducted from payroll.
//  - Status DEDUCTED : fully reconciled through payroll (set explicitly).
//
// LIFECYCLE PORTABILITY:
//  entityType + entityId mirrors the Document model pattern.
//  On Candidate→Employee conversion the records are reassigned to
//  entityType=EMPLOYEE, entityId=<employee.id> so they stay visible
//  in the Employee profile (same as Document migration behaviour).
//
//  applicantId (stable person reference):
//  Stores the original applicant UUID that survives the conversion.
//  Allows querying "all financial records for this person across all stages".
//  Set at record creation and never changed.
//
//  stageAtCreation: the lifecycle stage of the person when the record was
//  created. Values: 'LEAD' | 'CANDIDATE' | 'EMPLOYEE'. Used for audit
//  display ("created during Candidate stage") without affecting ownership.
//
// TRANSACTION TYPE: controlled by TRANSACTION_TYPES constant in backend.
// PAYMENT METHOD  : controlled by PAYMENT_METHODS constant in backend.
// Both are stored as plain strings for flexibility without a lookup table.
model FinancialRecord {
  id                         String   @id @default(uuid())
  // ── Entity link (reassigned on conversion) ───────────────────────────────
  entityType                 String   // 'APPLICANT' | 'EMPLOYEE'
  entityId                   String
  // ── Stable person identity (never changes across lifecycle) ──────────────
  applicantId                String?  // original applicant UUID (null for manually created employee records with no applicant origin)
  stageAtCreation            String?  // 'LEAD' | 'CANDIDATE' | 'EMPLOYEE' — stage when record was created
  // ── Transaction details ──────────────────────────────────────────────────
  transactionDate            DateTime
  currency                   String   @default("EUR")
  transactionType            String
  description                String?
  paymentMethod              String?
  paidByName                 String?   // free-text for display
  paidById                   String?   // FK to User (nullable for legacy)
  // ── Amounts ──────────────────────────────────────────────────────────────
  companyDisbursedAmount     Decimal  @default(0) @db.Decimal(10, 2)
  employeeOrAgencyPaidAmount Decimal  @default(0) @db.Decimal(10, 2)
  // ── Deduction tracking ────────────────────────────────────────────────────
  status                     String   @default("PENDING") // PENDING | DEDUCTED
  deductionAmount            Decimal? @db.Decimal(10, 2)
  deductionDate              DateTime?
  payrollReference           String?
  notes                      String?
  createdById                String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  deletedAt                  DateTime?
  deletedBy                  String?
  deletionReason             String?

  paidByUser  User?                       @relation("FRPaidBy",      fields: [paidById],     references: [id])
  createdBy   User?                       @relation("FRCreatedBy",   fields: [createdById],  references: [id])
  attachments FinancialRecordAttachment[]

  @@index([entityType, entityId])
  @@index([applicantId])
  @@index([status])
  @@index([transactionDate])
  @@index([transactionType])
  @@map("financial_records")
}

// ── Job Ads ───────────────────────────────────────────────────────────────────
//
// Represents a published/draft job advertisement. Applicants who apply via the
// public listing are linked through Applicant.jobAdId (nullable FK).
//
// STATUS LIFECYCLE: DRAFT → PUBLISHED → ARCHIVED
// publishedAt is set automatically when status is moved to PUBLISHED.
model JobAd {
  id           String      @id @default(uuid())
  title        String
  slug         String      @unique
  category     String
  description  String      @db.Text
  city         String
  country      String
  contractType String      @default("Full-time")
  salaryMin    Decimal?    @db.Decimal(10, 2)
  salaryMax    Decimal?    @db.Decimal(10, 2)
  currency     String      @default("GBP")
  status       String      @default("DRAFT")  // DRAFT | PUBLISHED | ARCHIVED
  publishedAt  DateTime?
  createdById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  deletedBy    String?
  deletionReason String?

  createdBy  User?       @relation("JobAdsCreated", fields: [createdById], references: [id])
  applicants Applicant[]

  @@index([status])
  @@index([country])
  @@index([category])
  @@map("job_ads")
}

// Attachments for a single FinancialRecord (receipts, invoices, proof docs, etc.)
model FinancialRecordAttachment {
  id                String   @id @default(uuid())
  financialRecordId String
  name              String
  fileUrl           String
  mimeType          String?
  fileSize          Int?
  uploadedById      String?
  createdAt         DateTime @default(now())
  deletedAt         DateTime?
  deletedBy         String?
  deletionReason    String?

  financialRecord FinancialRecord @relation(fields: [financialRecordId], references: [id], onDelete: Cascade)
  uploadedBy      User?           @relation("FRAttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@map("financial_record_attachments")
}

// ── Workflow Pipelines ─────────────────────────────────────────────────────────
//
// A Pipeline is a named, ordered recruitment workflow that candidates move through.
// Multiple pipelines can co-exist (e.g. "UK Driver Onboarding", "EU Logistics Route").
// Stages inside a pipeline are ordered and can be traversed in parallel.
// Candidates are assigned to exactly one pipeline at Lead→Candidate conversion.
//
// STATUS LIFECYCLE:
//   Workflow:  ACTIVE | ARCHIVED
//   CandidateStageProgress: ACTIVE | COMPLETED | SKIPPED | BLOCKED
//   CandidateWorkflowAssignment: ACTIVE | COMPLETED | WITHDRAWN

enum WorkflowStatus {
  ACTIVE
  ARCHIVED
}

enum CandidateProgressStatus {
  ACTIVE
  COMPLETED
  SKIPPED
  BLOCKED
}

enum WorkflowAssignmentStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
}

enum ApprovalDecision {
  APPROVED
  REJECTED
  PENDING
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_LEAVE
  HALF_DAY
  HOLIDAY
}

enum VehicleType {
  TRUCK
  CAR
  VAN
  TANKER
  TRAILER
  REFRIGERATED_TRAILER
  SPECIALTY
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  IN_MAINTENANCE
  SCRAPPED
}

enum FuelType {
  DIESEL
  PETROL
  ELECTRIC
  HYBRID
  GAS
  OTHER
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Named recruitment workflow (e.g. "UK Driver Standard Onboarding")
model Workflow {
  id           String         @id @default(uuid())
  name         String
  description  String?        @db.Text
  status       WorkflowStatus @default(ACTIVE)
  isDefault    Boolean        @default(false)
  isPublic     Boolean        @default(true)
  color        String         @default("#2563EB")
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  deletedBy    String?
  deletionReason String?

  createdBy           User?                        @relation("WorkflowsCreated", fields: [createdById], references: [id])
  stages              WorkflowStage[]
  assignments         CandidateWorkflowAssignment[]
  employeeAssignments EmployeeWorkflowAssignment[]
  accessUsers         WorkflowAccessUser[]

  @@index([status])
  @@map("workflows")
}

/// Ordered stage within a Workflow
model WorkflowStage {
  id              String    @id @default(uuid())
  workflowId      String
  name            String
  description     String?
  order           Int
  color           String    @default("#6366F1")
  slaHours        Int?
  requiresApproval Boolean  @default(false)
  isFinal         Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workflow              Workflow                       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  assignedUsers         WorkflowStageUser[]
  requiredDocs          WorkflowStageRequiredDoc[]
  candidateProgress     CandidateStageProgress[]
  employeeCurrentStages   EmployeeWorkflowAssignment[]   @relation("EmployeeCurrentStage")
  employeeStageApprovals  EmployeeStageApproval[]

  @@unique([workflowId, order])
  @@index([workflowId])
  @@map("workflow_stages")
}

/// Users assigned as owners/reviewers for a workflow stage
model WorkflowStageUser {
  stageId   String
  userId    String
  role      String   @default("REVIEWER")

  stage WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  user  User          @relation("WorkflowStageUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@id([stageId, userId])
  @@map("workflow_stage_users")
}

/// Document types required for a workflow stage to be completed
model WorkflowStageRequiredDoc {
  id             String  @id @default(uuid())
  stageId        String
  documentTypeId String
  isRequired     Boolean @default(true)

  stage        WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  documentType DocumentType  @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)

  @@unique([stageId, documentTypeId])
  @@map("workflow_stage_required_docs")
}

/// Users with explicit access to a private workflow
model WorkflowAccessUser {
  workflowId String
  userId     String
  grantedAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user     User     @relation("WorkflowAccess", fields: [userId], references: [id], onDelete: Cascade)

  @@id([workflowId, userId])
  @@map("workflow_access_users")
}

/// Assignment of a candidate to a Workflow
model CandidateWorkflowAssignment {
  id           String                    @id @default(uuid())
  candidateId  String
  workflowId   String
  status       WorkflowAssignmentStatus  @default(ACTIVE)
  assignedAt   DateTime                  @default(now())
  completedAt  DateTime?
  assignedById String?
  notes        String?

  candidate     Applicant              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  workflow      Workflow               @relation(fields: [workflowId], references: [id])
  assignedBy    User?                  @relation("WorkflowAssignments", fields: [assignedById], references: [id])
  stageProgress CandidateStageProgress[]

  @@index([candidateId])
  @@index([workflowId])
  @@map("candidate_workflow_assignments")
}

/// Tracks a candidate's progress through one workflow stage.
/// Multiple active rows per assignment are allowed (parallel stages).
model CandidateStageProgress {
  id           String                  @id @default(uuid())
  assignmentId String
  stageId      String
  status       CandidateProgressStatus @default(ACTIVE)
  enteredAt    DateTime                @default(now())
  completedAt  DateTime?
  slaDeadline  DateTime?
  flagged      Boolean                 @default(false)
  flagReason   String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  assignment CandidateWorkflowAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  stage      WorkflowStage               @relation(fields: [stageId], references: [id])
  approvals  CandidateStageApproval[]
  notes      CandidateStageNote[]

  @@index([assignmentId])
  @@index([stageId])
  @@index([status])
  @@map("candidate_stage_progress")
}

/// Approval record for a stage that requires sign-off
model CandidateStageApproval {
  id          String           @id @default(uuid())
  progressId  String
  decision    ApprovalDecision @default(PENDING)
  approvedById String?
  notes       String?
  decidedAt   DateTime?
  createdAt   DateTime         @default(now())

  progress    CandidateStageProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  approvedBy  User?                  @relation("StageApprovals", fields: [approvedById], references: [id])

  @@index([progressId])
  @@map("candidate_stage_approvals")
}

/// Notes left on a candidate's stage progress (internal or public)
model CandidateStageNote {
  id         String   @id @default(uuid())
  progressId String
  content    String   @db.Text
  isPrivate  Boolean  @default(false)
  authorId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  progress CandidateStageProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  author   User?                  @relation("StageNoteAuthors", fields: [authorId], references: [id])

  @@index([progressId])
  @@map("candidate_stage_notes")
}

/// Links an Employee to a recruitment Workflow for post-hire tracking
model EmployeeWorkflowAssignment {
  id             String                   @id @default(uuid())
  employeeId     String                   @unique
  workflowId     String
  currentStageId String?
  status         WorkflowAssignmentStatus @default(ACTIVE)
  assignedAt     DateTime                 @default(now())
  completedAt    DateTime?
  assignedById   String?
  notes          String?

  employee     Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workflow     Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  currentStage WorkflowStage? @relation("EmployeeCurrentStage", fields: [currentStageId], references: [id], onDelete: SetNull)
  assignedBy   User?          @relation("EmployeeWorkflowAssignments", fields: [assignedById], references: [id])

  @@index([workflowId])
  @@map("employee_workflow_assignments")
}

model EmployeeStageApproval {
  id           String   @id @default(uuid())
  employeeId   String
  stageId      String
  approvedById String
  approvedAt   DateTime @default(now())
  notes        String?

  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  stage      WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  approvedBy User          @relation("EmployeeStageApprovals", fields: [approvedById], references: [id])

  @@unique([employeeId, stageId])
  @@index([employeeId])
  @@map("employee_stage_approvals")
}

/// Daily attendance record for an employee
model AttendanceRecord {
  id           String           @id @default(uuid())
  employeeId   String
  date         DateTime         @db.Date
  status       AttendanceStatus @default(PRESENT)
  checkIn      String?
  checkOut     String?
  workingHours Float?
  notes        String?
  createdById  String?
  updatedById  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  employee  Employee @relation("EmployeeAttendance", fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("AttendanceCreatedBy", fields: [createdById], references: [id])
  updatedBy User?    @relation("AttendanceUpdatedBy", fields: [updatedById], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendance_records")
}

// ═══════════════════════════════════════════════════════════════════════════════
// VEHICLE MANAGEMENT MODULE
// ═══════════════════════════════════════════════════════════════════════════════

/// Workshop / garage used for vehicle maintenance
model Workshop {
  id          String    @id @default(uuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  city        String?
  country     String?
  notes       String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  maintenanceRecords MaintenanceRecord[]

  @@map("workshops")
}

/// Configurable maintenance/service type (e.g. "Oil Change", "Tyre Rotation")
model MaintenanceType {
  id                  String    @id @default(uuid())
  name                String
  description         String?
  defaultIntervalDays Int?
  defaultIntervalKm   Int?
  isActive            Boolean   @default(true)
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  maintenanceRecords MaintenanceRecord[]

  @@map("maintenance_types")
}

/// Vehicle master record
model Vehicle {
  id                  String        @id @default(uuid())
  registrationNumber  String        @unique
  type                VehicleType
  status              VehicleStatus @default(ACTIVE)
  make                String
  model               String
  year                Int?
  color               String?
  vin                 String?       @unique
  fuelType            FuelType?
  currentMileage      Int?
  notes               String?
  // Compliance expiry dates
  motExpiryDate       DateTime?     @db.Date
  taxExpiryDate       DateTime?     @db.Date
  insuranceExpiryDate DateTime?     @db.Date
  // Type-specific fields
  grossWeight         Float?
  payloadCapacity     Float?
  numberOfAxles       Int?
  tankerCapacity      Float?
  refrigerationUnit   String?
  trailerLength       Float?
  agencyId            String?
  createdById         String?
  updatedById         String?
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  agency             Agency?                   @relation(fields: [agencyId], references: [id])
  createdBy          User?                     @relation("VehicleCreatedBy", fields: [createdById], references: [id])
  updatedBy          User?                     @relation("VehicleUpdatedBy", fields: [updatedById], references: [id])
  driverAssignments  VehicleDriverAssignment[]
  documents          VehicleDocument[]
  maintenanceRecords MaintenanceRecord[]

  @@index([registrationNumber])
  @@index([status])
  @@index([type])
  @@map("vehicles")
}

/// Maps a driver (employee) to a vehicle — one active assignment per vehicle
model VehicleDriverAssignment {
  id         String    @id @default(uuid())
  vehicleId  String
  employeeId String
  startDate  DateTime  @db.Date
  endDate    DateTime? @db.Date
  isActive   Boolean   @default(true)
  notes      String?
  createdAt  DateTime  @default(now())

  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([employeeId])
  @@map("vehicle_driver_assignments")
}

/// Vehicle-specific document (independent of employee documents)
model VehicleDocument {
  id           String    @id @default(uuid())
  vehicleId    String
  name         String
  documentType String
  fileUrl      String?
  fileName     String?
  fileSize     Int?
  expiryDate   DateTime? @db.Date
  issuedDate   DateTime? @db.Date
  issuer       String?
  notes        String?
  uploadedById String?
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vehicle    Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("VehicleDocUploadedBy", fields: [uploadedById], references: [id])

  @@index([vehicleId])
  @@map("vehicle_documents")
}

/// Service / maintenance log entry for a vehicle
model MaintenanceRecord {
  id                 String            @id @default(uuid())
  vehicleId          String
  maintenanceTypeId  String?
  workshopId         String?
  status             MaintenanceStatus @default(SCHEDULED)
  scheduledDate      DateTime?         @db.Date
  completedDate      DateTime?         @db.Date
  mileageAtService   Int?
  nextServiceDate    DateTime?         @db.Date
  nextServiceMileage Int?
  cost               Float?
  laborCost          Float?
  partsCost          Float?
  description        String?
  technicianName     String?
  invoiceNumber      String?
  notes              String?
  createdById        String?
  updatedById        String?
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  vehicle         Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceType MaintenanceType? @relation(fields: [maintenanceTypeId], references: [id])
  workshop        Workshop?        @relation(fields: [workshopId], references: [id])
  createdBy       User?            @relation("MaintenanceCreatedBy", fields: [createdById], references: [id])
  updatedBy       User?            @relation("MaintenanceUpdatedBy", fields: [updatedById], references: [id])
  spareParts      MaintenanceRecordSparePart[]

  @@index([vehicleId])
  @@index([status])
  @@index([scheduledDate])
  @@map("maintenance_records")
}

/// Spare parts used in a maintenance record
model MaintenanceRecordSparePart {
  id                  String   @id @default(uuid())
  maintenanceRecordId String
  partName            String
  partNumber          String?
  quantity            Int      @default(1)
  unitCost            Float?
  totalCost           Float?
  supplier            String?
  createdAt           DateTime @default(now())

  maintenanceRecord MaintenanceRecord @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)

  @@index([maintenanceRecordId])
  @@map("maintenance_record_spare_parts")
}

// ── Database Backup ────────────────────────────────────────────────────────────

model SystemBackup {
  id           String    @id @default(uuid())
  fileName     String
  filePath     String
  fileSize     BigInt?
  backupType   String    @default("FULL")
  status       String    @default("PENDING")
  notes        String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  createdById  String?

  createdBy User? @relation("BackupCreatedBy", fields: [createdById], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("system_backups")
}

// ── Auth Token Models ─────────────────────────────────────────────────────────

model ActivationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("activation_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  type      String    @default("USER_INITIATED") // USER_INITIATED | ADMIN_INITIATED
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

// ── Candidate Delete Requests ─────────────────────────────────────────────────

model CandidateDeleteRequest {
  id            String    @id @default(uuid())
  candidateId   String
  applicant     Applicant @relation(fields: [candidateId], references: [id])
  requestedById String
  requestedBy   User      @relation("DeleteRequestedBy", fields: [requestedById], references: [id])
  reason        String
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedById  String?
  reviewedBy    User?     @relation("DeleteRequestReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  reviewNotes   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("candidate_delete_requests")
}

// ── Per-user Permission Overrides ─────────────────────────────────────────────

model AgencyUserPermission {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission  String   // e.g. "finance:read", "candidates:delete"
  granted     Boolean  @default(true)  // true=grant override, false=revoke override
  grantedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, permission])
  @@map("agency_user_permissions")
}

// ── User Number Sequence ───────────────────────────────────────────────────────

model UserNumberSequence {
  id      Int @id @default(autoincrement())
  current Int @default(0)

  @@map("user_number_sequences")
}
